{
  "name": "wa-manage-desktop",
  "version": "1.0.0",
  "description": "WhatsApp Multi-Account Desktop App",
  "main": "dist/main/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json -w",
    "dev": "npm run build:main && npm run build:renderer && electron .",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.main.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@whiskeysockets/baileys": "7.0.0-rc13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.22.0",
    "pino": "^10.3.1",
    "pino-std-serializers": "^7.1.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.5.2",
    "electron": "^42.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.12.0",
    "eslint-plugin-react": "^7.34.1",
    "ico-endec": "^0.1.6",
    "postcss": "^8.5.16",
    "shadcn": "^4.12.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.10.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.wamanage.desktop",
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "icon": "assets/icon.png",
    "directories": {
      "buildResources": "assets",
      "output": "release"
    }
  }
}
