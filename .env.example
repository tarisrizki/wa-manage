# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secretpassword
POSTGRES_DB=wa_dashboard

# --- Chatwoot ---
SECRET_KEY_BASE=replace_this_with_a_secure_random_string
CHATWOOT_FRONTEND_URL=http://localhost:3000
# Token dan Account ID didapatkan setelah login pertama kali di Chatwoot
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_ACCESS_TOKEN=your_chatwoot_access_token

# --- Evolution API ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=replace_this_with_a_secure_api_key
